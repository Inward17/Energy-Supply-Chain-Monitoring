# =============================================================================
# Energy Supply Chain Resilience OS — Backend Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# The .env file must exist BEFORE running docker-compose up.
#
# What breaks without each key is documented inline below.
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Required — the dashboard will not start without a valid DB connection.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=energy_resilience
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# ── Neo4j ─────────────────────────────────────────────────────────────────────
# Required — the Reroute Matrix (chokepoint rerouting) will return empty results
# without a Neo4j connection.
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ── Gemini AI ──────────────────────────────────────────────────────────────────
# Get free key instantly (no credit card): https://aistudio.google.com/app/apikey
# Without this: Sentinel Agent is disabled and War Room briefings show a placeholder.
#               All historical data, charts, SPR simulator, and Reroute Matrix still work.
GEMINI_API_KEY=your_gemini_api_key

# ── AISStream.io ───────────────────────────────────────────────────────────────
# Get free key instantly: https://aisstream.io
# Without this: Threat Map shows last-known vessel positions from seed data instead
#               of live positions. A banner is displayed explaining the degradation.
AISSTREAM_API_KEY=your_aisstream_api_key

# ── SDI Formula Weights ────────────────────────────────────────────────────────
# IMPORTANT: These four values must sum exactly to 1.0.
# Changing them rebalances the Supply Disruption Index formula.
SDI_W1=0.40    # Gemini geopolitical risk score component
SDI_W2=0.25    # Vessel density anomaly component (AIS data)
SDI_W3=0.15    # Brent crude price deviation component
SDI_W4=0.20    # Freight cost deviation component (BOAT ETF proxy)

# ── Cron Worker ────────────────────────────────────────────────────────────────
CRON_INTERVAL_MINUTES=60    # How often the background pipeline refreshes (minutes)
AIS_SNAPSHOT_SECONDS=120    # How long to collect AIS vessel data per cron cycle
