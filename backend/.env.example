# =============================================================================
# Energy Supply Chain Resilience OS — Backend Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# The .env file must exist BEFORE running docker-compose up.
#
# What breaks without each key is documented inline below.
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Required — the dashboard will not start without a valid DB connection.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=energy_resilience
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# ── Neo4j ─────────────────────────────────────────────────────────────────────
# Required — the Reroute Matrix (chokepoint rerouting) will return empty results
# without a Neo4j connection.
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ── Gemini AI ──────────────────────────────────────────────────────────────────
# Get free key instantly (no credit card): https://aistudio.google.com/app/apikey
# Without this: Sentinel Agent is disabled and War Room briefings show a placeholder.
#               All historical data, charts, SPR simulator, and Reroute Matrix still work.
GEMINI_API_KEY=your_gemini_api_key

# Optional pool of additional keys (comma-separated), tried in order when the
# primary returns 429/RESOURCE_EXHAUSTED. The free tier caps requests per key,
# so a pool keeps the Sentinel scoring through a news burst rather than
# stalling until the quota window resets.
GEMINI_API_KEYS=

# Model used for scoring. Note gemini-2.5-flash returns 404 for API accounts
# created after Google restricted it, so a mixed-age key pool must standardise
# on an alias every key can call. Keeping one model across all keys also keeps
# severity scoring calibrated consistently.
GEMINI_MODEL=gemini-flash-latest

# ── AISStream.io ───────────────────────────────────────────────────────────────
# Get free key instantly: https://aisstream.io
# Without this: Threat Map shows last-known vessel positions from seed data instead
#               of live positions. A banner is displayed explaining the degradation.
AISSTREAM_API_KEY=your_aisstream_api_key

# ── SDI Formula Weights ────────────────────────────────────────────────────────
# IMPORTANT: These four values must sum exactly to 1.0.
# Changing them rebalances the Supply Disruption Index formula.
SDI_W1=0.50    # Gemini geopolitical risk score component
SDI_W2=0.25    # Vessel density anomaly component (AIS data)
SDI_W3=0.10    # Brent crude price deviation component
SDI_W4=0.15    # Freight cost deviation component (BOAT ETF proxy)

# ── News fallback providers ───────────────────────────────────────────────────
# GDELT is the primary source (no key, unmetered) but throttles hard per IP.
# These take over when it is blocked, tried freshest-first. Without them, a
# sustained GDELT block leaves the Sentinel with no headlines at all.
NEWSDATA_API_KEY=            # newsdata.io   — 200 req/day, real-time
GNEWS_API_KEY=               # gnews.io      — 100 req/day, ~12h delay
NEWSAPI_API_KEY=             # newsapi.org   — 100 req/day, ~24h delay, non-commercial

# GDELT lookback window per call.
GDELT_TIMESPAN=12h

# ── Deployment ────────────────────────────────────────────────────────────────
# Comma-separated origins allowed to call this API from a browser. The frontend
# fetches directly, so the deployed frontend's origin must be listed here or
# every request is blocked by CORS. Never use "*": these endpoints are
# unauthenticated and spend metered Gemini/news quota.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# Days of vessel_telemetry to keep. Nothing reads past 7 days (the density
# baseline uses 7, live positions 24h); 14 leaves margin. This is the only
# table that grows without bound.
TELEMETRY_RETENTION_DAYS=14

# ── Cron Worker ────────────────────────────────────────────────────────────────
CRON_INTERVAL_MINUTES=15    # How often the background pipeline refreshes (minutes)
AIS_SNAPSHOT_SECONDS=600    # How long to collect AIS vessel data per cron cycle.
                            # Keep above ~360s: ship type arrives in Type-5
                            # (ShipStaticData) messages broadcast roughly every
                            # 6 minutes, while positions arrive every few
                            # seconds. A shorter window types only ~window/360
                            # of vessels, which thins the sample the SDI
                            # vessel-density baseline is built from.

# ── Scoring calibration ─────────────────────────────────────────────────────
FREIGHT_RATE_SENSITIVITY=0.50   # Symmetric BOAT-index adjustment around 0.50
MARKET_Z_CLIP_SIGMAS=4.5        # Market-tail normalisation window
ELEVATED_RISK_THRESHOLD=0.50    # Chokepoint risk threshold for price impact
RISK_EVENT_HALF_LIFE_DAYS=14    # Default; type-specific half-lives override it
