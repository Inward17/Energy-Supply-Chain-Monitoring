# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
.env
scratch/
scratch_tree.py
frontend/playwright-report/
frontend/test-results/
.venv/
venv/
downloads/
eggs/
.eggs/
# Anchored to the repo root: unanchored "lib/" also matched frontend/lib/,
# silently keeping the frontend's API client and utils out of the repo. A
# virtualenv's lib/ is already covered by the venv/ and .venv/ rules below.
/lib/
/lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nosenv/
.pytest_cache/
. Moffat_cache/
.cache/
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.run/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Sphinx documentation
docs/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if having platform-specific dependencies or dependencies
#   having no cross-platform support, pipenv may install dependencies that don't work, or not
#   install all needed dependencies.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains the exact dependency versions locked.
#   It is recommended to check this in.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains the exact dependency versions locked.
#   It is recommended to check this in.
#pdm.lock

# virtualenv
venv/
.venv/
ENV/
env/
Active.ps1

# IDEs and editors
.idea/
.vscode/
*.swp
*.swo
.project
.pydevproject
.settings/

# Local configuration
.env
.env.*
!.env.example

# Logs and databases
*.log
*.sqlite
*.db
*.lock
cron_worker.lock

# Node / Next.js (frontend)
node_modules/
.next/
out/
frontend/.env.local
frontend/.env.*.local
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*

# pnpm lock (large; regenerated on install)
pnpm-lock.yaml

# TypeScript incremental build cache — regenerated on every build and
# otherwise shows up as a diff in unrelated commits.
frontend/tsconfig.tsbuildinfo
*.tsbuildinfo

# Playwright output
frontend/playwright-report/
frontend/test-results/

# Editor / agent tooling. launch.json is shared (it defines how to start the
# dev server); local overrides and session state are not.
.claude/settings.local.json
.claude/sessions/
.claude/plans/

# Local database dumps taken for migration. Real collected data, regenerated
# on demand with pg_dump — not something to carry in the repo.
seed/local_data.sql

# Scratch files
*.orig
*.rej
_tmp_*
